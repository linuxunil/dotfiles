# ~/.config/ghostty/config
# Main configuration file for Ghostty

# --- Font Configuration ---
font-family = "FiraCode Nerd Font"
font-size = 14

# --- Theme & Appearance ---
# Using the built-in "tokyonight" theme.
theme = "tokyonight"
background-opacity = 0.95
window-decoration = "none"
window-padding-x = 10
window-padding-y = 10

# --- Keybindings (macOS Style) ---
# Using the correct action:argument syntax.
keybind = "super+c=copy_to_clipboard"
keybind = "super+v=paste_from_clipboard"
keybind = "super+t=new_tab"
keybind = "super+w=close_tab"
keybind = "super+n=new_window"
keybind = "super+q=quit"
keybind = "super+1=goto_tab:1"
keybind = "super+2=goto_tab:2"
keybind = "super+3=goto_tab:3"
keybind = "super+4=goto_tab:4"
keybind = "super+5=goto_tab:5"
keybind = "super+6=goto_tab:6"
keybind = "super+7=goto_tab:7"
keybind = "super+8=goto_tab:8"
keybind = "super+9=goto_tab:9"