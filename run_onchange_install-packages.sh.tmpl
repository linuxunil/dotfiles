#!/bin/bash
#
# This script is executed by chezmoi on `chezmoi apply`.
# It installs system-level dependencies and virtualization tools.
# Core CLI tools (bat, eza, zoxide) are now managed by mise.
#

set -eufo pipefail

echo "--- Starting package installation ---"

{{ if eq .chezmoi.os "linux" -}}
# --- Fedora (Linux) ---
echo "Installing virtualization tools..."
sudo dnf install -y @vagrant


{{ else if eq .chezmoi.os "darwin" -}}
# --- macOS ---
echo "Updating Homebrew..."
brew update

echo "Installing Vagrant and VirtualBox casks..."
brew install --cask vagrant virtualbox

echo "NOTE: On macOS, you may need to go to 'System Settings > Privacy & Security' to approve the VirtualBox kernel extension after the first run."

{{ end -}}

echo "--- Package installation complete ---"

